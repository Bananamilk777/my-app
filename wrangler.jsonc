{
  "name": "my-app",
  "compatibility_date": "2026-03-15",
  "main": "worker/index.js",
  // Set with `wrangler secret put YOUTUBE_API_KEY`
  // Optional for caption download attempts: `wrangler secret put YOUTUBE_OAUTH_ACCESS_TOKEN`
  // Set with `wrangler secret put NAVER_CLIENT_ID`
  // Set with `wrangler secret put NAVER_CLIENT_SECRET`
  // Optional affiliate template, e.g. https://...{{URL}} : `wrangler secret put COUPANG_AFFILIATE_TEMPLATE`
  "assets": {
    "directory": "."
  }
}
